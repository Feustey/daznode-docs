{
  "name": "daznode-docs",
  "version": "1.0.0",
  "description": "Documentation pour Daznode - nœud Lightning Network",
  "main": "index.js",
  "scripts": {
    "build": "eleventy",
    "dev": "eleventy --serve --port=8080",
    "fix-frontmatter": "node scripts/fix-frontmatter.js",
    "add-layout": "node scripts/add-layout.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "postbuild": "npm run generate-sitemap && cp robots.txt public/",
    "build:css": "postcss assets/css/style.css -o public/style.css",
    "watch:css": "postcss assets/css/style.css -o public/style.css --watch"
  },
  "keywords": [
    "documentation",
    "daznode",
    "lightning",
    "bitcoin"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy": "^2.0.1",
    "fuse.js": "^7.0.0",
    "glob": "^11.0.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.18",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.17"
  }
}
